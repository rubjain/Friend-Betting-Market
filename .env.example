# PostgreSQL connection string (Supabase pooler, port 6543, or local Postgres).
# Without this, the app runs in demo mode with seeded in-memory state.
# See README.md for Supabase and Railway setup instructions.
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection for Prisma migrations (port 5432). Optional if supabaseTurnOn.js can derive it from DATABASE_URL.
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

# Secret used to sign session cookies. Must be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGORA_SESSION_SECRET="replace-with-a-long-random-secret"

# Set to "1" to enable the dev-admin toggle in the UI (never enable in production).
AGORA_DEV_ADMIN_SHORTCUT="0"

# App URL and sender for verification and password-reset emails.
AGORA_APP_URL="http://127.0.0.1:3000"
AGORA_EMAIL_FROM="Agora <no-reply@example.com>"

# Set to "1" only when you are ready to enable real-money compliance gates.
AGORA_REAL_MONEY_MODE="0"

# Optional: disable ESPN live scoreboard (demo board used instead).
# AGORA_DISABLE_ESPN="0"

# Optional: JSON map of userId -> admin level for fine-grained admin permissions.
# AGORA_ADMIN_LEVELS_JSON="{}"

# Optional email delivery (used by lib/server/email.js). If unset, the app logs email
# tokens/links in development instead of sending them.
EMAIL_USER=""
EMAIL_PASS=""
