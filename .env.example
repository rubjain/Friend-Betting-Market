# PostgreSQL connection string.
# Without this, the app runs in demo mode with seeded in-memory state.
# See README.md for Supabase and Railway setup instructions.
DATABASE_URL="postgresql://friendmarket:friendmarket@localhost:5432/friendmarket?schema=public"

# Secret used to sign session cookies. Must be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FRIENDMARKET_SESSION_SECRET="replace-with-a-long-random-secret"

# Set to "1" to enable the dev-admin toggle in the UI (never enable in production).
FRIENDMARKET_DEV_ADMIN_SHORTCUT="0"

# Future email provider settings for verification and password-reset delivery.
# Development API responses expose tokens directly; production must send links by email instead.
FRIENDMARKET_APP_URL="http://127.0.0.1:3000"
FRIENDMARKET_EMAIL_FROM="Agora <no-reply@example.com>"

# Set to "1" only when you are ready to enable real-money compliance gates.
# Until then, keep this disabled and treat withdrawable balances as play-money.
FRIENDMARKET_REAL_MONEY_MODE="0"

# Optional email delivery (used by lib/server/email.js). If unset, the app logs email
# tokens/links in development instead of sending them.
EMAIL_USER=""
EMAIL_PASS=""
APP_URL="http://127.0.0.1:3000"
